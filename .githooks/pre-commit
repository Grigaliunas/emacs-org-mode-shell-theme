#!/usr/bin/env bash
# Regenerate CHECKSUMS.txt so it never drifts from the committed files.
# Enable with: git config core.hooksPath .githooks
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

if command -v shasum >/dev/null 2>&1; then
  __sum() { shasum -a 256; }
elif command -v sha256sum >/dev/null 2>&1; then
  __sum() { sha256sum; }
else
  echo "pre-commit: neither shasum nor sha256sum found; cannot update CHECKSUMS.txt" >&2
  exit 1
fi

# The manifest itself and repo plumbing are not part of the distributed theme.
EXCLUDE='^(CHECKSUMS\.txt|\.gitignore|\.githooks/)'

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

# Hash blobs from the index, not the working tree: with a partial `git add -p`
# the two differ, and the manifest must describe what is actually committed.
while IFS= read -r path; do
  printf '%s  %s\n' "$(git cat-file blob ":$path" | __sum | cut -d' ' -f1)" "$path"
done < <(git ls-files | grep -Ev "$EXCLUDE" | LC_ALL=C sort) > "$tmp"

if ! cmp -s "$tmp" CHECKSUMS.txt 2>/dev/null; then
  cp "$tmp" CHECKSUMS.txt
  git add CHECKSUMS.txt
  echo "pre-commit: regenerated CHECKSUMS.txt"
fi
