CHR 40;38;5;181
ORPHAN 40;38;5;181
MISSING 00;38;5;181
EXEC 01;38;5;107
SETUID 37;41
SETGID 30;43
CAPABILITY 30;41
STICKY_OTHER_WRITABLE 30;42
OTHER_WRITABLE 34;42
STICKY 37;44

