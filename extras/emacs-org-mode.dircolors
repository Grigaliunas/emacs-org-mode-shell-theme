# Emacs Org Mode dircolors for GNU ls
# Load with: eval "$(dircolors -b emacs-org-mode.dircolors)"
TERM xterm-256color
TERM screen-256color
TERM tmux-256color
TERM alacritty
TERM foot
TERM kitty
TERM xterm-kitty

# Attribute codes use 256-color approximations of the Emacs Org Mode palette.
# bg0 #1c1c1c, fg #d0d0d0, cyan #7cb8bb, bright cyan #8cd0d3,
# green #6fb86f, comment #7f9f7f, yellow #f0dfaf, red #cc9393.
NORMAL 00
FILE 00;38;5;252
DIR 01;38;5;109
